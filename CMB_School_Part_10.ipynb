   "source": [
    "delta_ell = 30\n",
    "ell_max = 4000\n",
    "\n",
    "ells, C_TT_unlensed = calculate_2d_spectrum(unlensed,delta_ell,ell_max,pix_size,N)\n",
    "ells, C_TT_lensed = calculate_2d_spectrum(lensed,delta_ell,ell_max,pix_size,N)\n",
    "\n",
    "plt.semilogy(ells, ells*(ells + 1) * C_TT_unlensed/(2*np.pi))\n",
    "plt.semilogy(ells, ells*(ells + 1) * C_TT_lensed/(2*np.pi))\n",
    "plt.show()\n",
    "\n",
    "plt.plot(ells, C_TT_lensed / C_TT_unlensed)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 56,
   "metadata": {},
   "outputs": [
    {
     "data": {
